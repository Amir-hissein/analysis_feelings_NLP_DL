# Environnement virtuel
venv/
.venv/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Données (souvent trop lourdes / privées pour Git)
data/raw/*
data/processed/*
data/external/*
!data/**/.gitkeep

# Modèles entraînés (lourds) — exclus par défaut
models/*
!models/.gitkeep
# EXCEPTIONS : les 2 petits artefacts de la baseline (222 Ko) sont versionnés
# car nécessaires au déploiement Docker + à la CI (image API self-contained).
!models/tfidf_vectorizer.joblib
!models/logreg_model.joblib
!models/tfidf_vectorizer_neg.joblib
!models/logreg_model_neg.joblib

# Système
.DS_Store

# Secrets / credentials (ne JAMAIS versionner)
.env
.env.*
*.pem
*.key
*_rsa
*_rsa.pub
credentials.json
secrets.*

# IDE
.vscode/
.idea/
